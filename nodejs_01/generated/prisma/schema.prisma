generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
}

model RequestLog {
  id        Int      @id @default(autoincrement())
  method    String
  path      String
  status    Int
  latencyMs Float
  ip        String?
  createdAt DateTime @default(now())
}

model ErrorLog {
  id        String   @id @default(uuid())
  message   String
  type      String?
  stack     String?
  path      String?
  method    String?
  createdAt DateTime @default(now())
}
